{
  "rules": {
    "players": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid && auth.token.email.matches(/@aguacamelo[.]com[.]br$/i)"
      }
    },
    "bets": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid && auth.token.email.matches(/@aguacamelo[.]com[.]br$/i)"
      }
    },
    "matches": { ".read": true, ".write": true },
    "config":  { ".read": true, ".write": true }
  }
}
